# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Optional: your dev server ID for instant slash command sync (right-click server → Copy Server ID)
# Leave unset in production — global sync propagates within ~1 hour
# DEV_GUILD_ID=your_server_id_here

# Optional: your Discord user ID to lock DMs to yourself
# OWNER_ID=your_user_id_here


# Optional: your Gemini API key from https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional: configure which team Harry tracks in his Discord presence.
# PRESENCE_TEAM    — MLB team code (default: DET). E.g. NYY, LAD, BOS, CHC.
# PRESENCE_TZ      — IANA timezone for day rollover and pre-game time display
#                    (default: America/New_York). Use the team's home tz.
# PRESENCE_DEFAULT_MSG — Fallback activity text when no game is active
#                        (default: "Juuust a bit outside.")
# PRESENCE_TEAM=DET
# PRESENCE_TZ=America/New_York
# PRESENCE_DEFAULT_MSG=Juuust a bit outside.